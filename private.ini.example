[common]
build_flags =
    -DPRIVATE_HOSTNAME=\"hostname, e.g. esp8266\"
    -DPRIVATE_WIFI_SSID=\"Your WiFi AP Name\"
    -DPRIVATE_WIFI_PASSWORD=\"Your WiFi Password\"
    -DPRIVATE_PC_AUTH=\"REPLACEME\"
    -DPRIVATE_PIN_POWER=D1
    -DPRIVATE_PIN_RESET=D2
    -DPRIVATE_PIN_DHT11=D4
    -DPRIVATE_NTP_LOCAL_PORT=7931
    -DPRIVATE_NTP_SERVER=\"pool.ntp.org\"
